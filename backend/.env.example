# Server
PORT=4000
# URL của frontend (để tạo link trong email xác nhận / đặt lại mật khẩu)
APP_URL=http://localhost:5173

# ─── Supabase (kết nối bằng API key — đơn giản, không cần chuỗi Postgres) ───
# Lấy ở: Supabase Dashboard → Project Settings → API
#   SUPABASE_URL              = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" key (mục Project API keys)
# ⚠️ service_role có TOÀN QUYỀN — chỉ đặt ở backend, TUYỆT ĐỐI không đưa ra frontend.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY= ...service_role key...

# JWT
JWT_SECRET=doi-thanh-chuoi-bi-mat-dai-ngau-nhien
JWT_EXPIRES_IN=7d

# Thư mục lưu file upload (chỉ dùng khi fallback xuống đĩa local)
UPLOAD_DIR=uploads
# Bucket Supabase Storage để lưu tài liệu/bài nộp (tự tạo public nếu chưa có).
# File lưu ở đây bền vững — build lại từ zip vẫn còn (khác với lưu đĩa local).
STORAGE_BUCKET=uploads

# ─── SMTP gửi email (xác nhận email + quên mật khẩu) ───
# Để TRỐNG khi dev → link sẽ in ra console thay vì gửi mail thật.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AutoGrade <no-reply@autograde.local>"

# ─── MÔ ĐUN CHẤM ĐIỂM ───
# Module 3 (phong cách code) → Google Gemini.
#   Lấy key MIỄN PHÍ ở: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model Gemini (mặc định gemini-2.5-flash; có thể đổi sang bản mới hơn vd gemini-3.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Module 5 (tổng kết & nhận xét) → Groq (API tương thích OpenAI).
#   Lấy key MIỄN PHÍ ở: https://console.groq.com/keys
GROQ_API_KEY=
# Model Groq. Mặc định openai/gpt-oss-120b (chất lượng cao).
#   Bản nhẹ/nhanh hơn: openai/gpt-oss-20b.
#   (Lưu ý: llama-3.3-70b-versatile đang bị Groq thông báo ngừng — tránh dùng.)
GROQ_MODEL=openai/gpt-oss-120b

# Thời gian chờ tối đa mỗi lần gọi LLM (ms)
LLM_TIMEOUT_MS=30000

# ─── Sandbox chạy code (module 1 testcase & module 2 độ phức tạp) ───
# Yêu cầu máy đã cài: python3/python, g++, javac/java (chỉ cần ngôn ngữ bạn định chấm).
# Lệnh Python được tự dò (python3 → python → py). Đặt biến này để ép dùng 1 lệnh cụ thể:
# PYTHON_CMD=python
SANDBOX_TIMEOUT_MS=5000            # giới hạn thời gian mỗi lần chạy 1 testcase
SANDBOX_COMPILE_TIMEOUT_MS=15000   # giới hạn thời gian biên dịch
SANDBOX_MEMORY_MB=256              # giới hạn RAM mỗi tiến trình
SANDBOX_MAX_OUTPUT=1000000         # giới hạn byte stdout/stderr thu thập

# (Tương thích cũ — không bắt buộc; nếu chỉ đặt GRADING_API_KEY thì nó được dùng làm GEMINI_API_KEY)
GRADING_API_KEY=
